{
  "name": "@cloud-dog/testing",
  "description": "Shared Playwright and accessibility testing helpers for Cloud-Dog web apps.",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "author": "Cloud-Dog, Viewdeck Engineering Limited",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.cloud-dog.net/",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viewdeck/cloud-dog-ai.git",
    "directory": "cloud-dog-ai-ui-monorepo/packages/testing"
  },
  "homepage": "https://cloud-dog.net",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run && playwright test"
  },
  "dependencies": {
    "@playwright/test": "^1.47.2",
    "axe-core": "^4.10.2",
    "@axe-core/playwright": "^4.10.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.5"
  }
}
